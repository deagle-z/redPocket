    "tabSecurity": "Account Security",
    "footerHint": "Didn't find the answer you need?",
    "contactCs": "Contact Support",
    "hot": {
      "h1": {
        "q": "What is Lucky Packet Thunder?",
        "a": "It is a packet-grab game where users join send/grab rounds with thunder rules and settle by game rules."
      },
      "h2": {
        "q": "How to recharge?",
        "a": "Go to Recharge page, choose a channel and amount, submit order, then complete payment."
      },
      "h3": {
        "q": "How to withdraw?",
        "a": "Go to Withdraw page, enter amount and submit. Funds are sent after approval."
      },
      "h4": {
        "q": "How to join the game?",
        "a": "Recharge first, then choose packets on the home page to join grabbing."
      },
      "h5": {
        "q": "What is a thunder number?",
        "a": "A thunder number is the tail-number rule used to determine thunder hits."
      }
    },
    "finance": {
      "f1": {
        "q": "Which recharge methods are supported?",
        "a": "Supported channels are those currently shown on the recharge page."
      },
      "f2": {
        "q": "Is there a minimum recharge amount?",
        "a": "Yes. The minimum amount follows the options shown on the recharge page."
      },
      "f3": {
        "q": "How long does withdrawal take?",
        "a": "Usually fast. It may be delayed during peak hours or risk review."
      },
      "f4": {
        "q": "Is there a withdrawal fee?",
        "a": "Whether fees apply and the rate depend on the current withdraw page notice."
      }
    },
    "game": {
      "g1": {
        "q": "How to set thunder number?",
        "a": "Choose the thunder number when sending a packet."
      },
      "g2": {
        "q": "How is packet amount distributed?",
        "a": "The system splits it into multiple random sub-packets by rule."
      },
      "g3": {
        "q": "How is thunder determined?",
        "a": "It depends on whether a sub-packet tail number matches the thunder number."
      },
      "g4": {
        "q": "What happens after thunder hit?",
        "a": "After thunder hit, amount is deducted and settled to the sender by current rules."
      },
      "g5": {
        "q": "Any other win/loss rules besides thunder?",
        "a": "Platform fee and event rules may also affect result."
      },
      "g6": {
        "q": "Is there a fee for grabbing packets?",
        "a": "If any fee applies, it will be shown on page; otherwise current rules apply."
      },
      "g7": {
        "q": "Is there a fee for sending packets?",
        "a": "The platform may take commission from sender income. See page for current ratio."
      },
      "g8": {
        "q": "How long is packet validity?",
        "a": "If not fully grabbed before timeout, it ends automatically."
      }
    },
    "security": {
      "s1": {
        "q": "How to protect my account?",
        "a": "Do not share code/password/login info and beware of phishing links."
      },
      "s2": {
        "q": "What if I forget password?",
        "a": "Use Forgot Password on the login page and reset via email code."
      },
      "s3": {
        "q": "What if my account is stolen?",
        "a": "Change password immediately and contact support."
      },
      "s4": {
        "q": "How to enable 2FA?",
        "a": "Enable via platform entry once the feature is available."
      }
    }
  }
}
